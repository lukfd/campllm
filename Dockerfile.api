# Use a standard python image as the base
FROM python:3.14-slim

# Install uv by copying it from the official image
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

# Set the working directory
WORKDIR /app

# Copy dependency definitions
COPY pyproject.toml .
COPY uv.lock . 

# Install dependencies
# --frozen ensures we use the exact lockfile versions
# --no-install-project avoids installing the current project code yet
RUN uv sync --frozen --no-install-project

# Copy the rest of the application code
COPY src ./src

# Expose the port
EXPOSE 8000

# Use the virtual environment created by uv
# uv sync creates a .venv directory by default
ENV PATH="/app/.venv/bin:$PATH"

# Run the application
CMD ["uvicorn", "src.api.main:app", "--host", "0.0.0.0", "--port", "8000"]